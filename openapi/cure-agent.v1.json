{
  "openapi": "3.0.0",
  "paths": {
    "/api/v1/health": {
      "get": {
        "operationId": "HealthController_check",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponseDto"
                    },
                    {
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/HealthResponseDto"
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        },
        "summary": "서버 상태 확인",
        "tags": [
          "Health"
        ]
      }
    },
    "/api/v1/auth/signup": {
      "post": {
        "operationId": "AuthController_signUp",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignUpRequestDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponseDto"
                    },
                    {
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/AuthSessionResponseDto"
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        },
        "summary": "의료인 가입 + 즉시 로그인 (쿠키 발급)",
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/v1/auth/login": {
      "post": {
        "operationId": "AuthController_login",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequestDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponseDto"
                    },
                    {
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/AuthSessionResponseDto"
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        },
        "summary": "이메일 로그인 (쿠키 발급)",
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/v1/auth/refresh": {
      "post": {
        "operationId": "AuthController_refresh",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponseDto"
                    },
                    {
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/AuthSessionResponseDto"
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        },
        "summary": "access 재발급 + refresh rotation",
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/v1/auth/logout": {
      "post": {
        "operationId": "AuthController_logout",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "summary": "로그아웃 — 세션 family 폐기 + access 즉시 무효화 + 쿠키 만료",
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/v1/auth/me": {
      "get": {
        "operationId": "AuthController_me",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponseDto"
                    },
                    {
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/ClinicianResponseDto"
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        },
        "summary": "현재 사용자 복구",
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/v1/auth/email-availability": {
      "get": {
        "operationId": "AuthController_emailAvailability",
        "parameters": [
          {
            "name": "email",
            "required": true,
            "in": "query",
            "schema": {
              "example": "doctor@clinic.kr",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponseDto"
                    },
                    {
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/EmailAvailabilityResponseDto"
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        },
        "summary": "이메일 중복 확인 (rate limit 적용)",
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/v1/guidelines": {
      "get": {
        "operationId": "GuidelineController_list",
        "parameters": [
          {
            "name": "query",
            "required": false,
            "in": "query",
            "description": "제목 부분일치 검색",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "required": false,
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "ACTIVE",
                "SUPERSEDED"
              ]
            }
          },
          {
            "name": "publisher",
            "required": false,
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "cursor",
            "required": false,
            "in": "query",
            "description": "불투명 커서 (§10.4)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "size",
            "required": false,
            "in": "query",
            "schema": {
              "maximum": 50,
              "default": 20,
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponseDto"
                    },
                    {
                      "properties": {
                        "data": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/GuidelineSummaryResponseDto"
                          }
                        },
                        "page": {
                          "$ref": "#/components/schemas/PageMetaDto"
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        },
        "summary": "지침 검색·필터 목록 (커서 기반)",
        "tags": [
          "Guideline"
        ]
      }
    },
    "/api/v1/guidelines/{guidelineId}": {
      "get": {
        "operationId": "GuidelineController_detail",
        "parameters": [
          {
            "name": "guidelineId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponseDto"
                    },
                    {
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/GuidelineDetailResponseDto"
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        },
        "summary": "지침 상세 (현재 버전 포함)",
        "tags": [
          "Guideline"
        ]
      }
    },
    "/api/v1/guidelines/{guidelineId}/evidence": {
      "get": {
        "operationId": "GuidelineController_listEvidence",
        "parameters": [
          {
            "name": "guidelineId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "cursor",
            "required": false,
            "in": "query",
            "description": "불투명 커서 (§10.4)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "size",
            "required": false,
            "in": "query",
            "schema": {
              "maximum": 50,
              "default": 20,
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponseDto"
                    },
                    {
                      "properties": {
                        "data": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/EvidenceSummaryResponseDto"
                          }
                        },
                        "page": {
                          "$ref": "#/components/schemas/PageMetaDto"
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        },
        "summary": "지침의 섹션·권고문(근거 청크) 목록",
        "tags": [
          "Guideline"
        ]
      }
    },
    "/api/v1/evidence/{evidenceId}": {
      "get": {
        "operationId": "EvidenceController_detail",
        "parameters": [
          {
            "name": "evidenceId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponseDto"
                    },
                    {
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/EvidenceDetailResponseDto"
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        },
        "summary": "인용 근거 원문 상세",
        "tags": [
          "Evidence"
        ]
      }
    }
  },
  "info": {
    "title": "Cure Agent API",
    "description": "한의 임상 지침 기반 어시스턴트 API. 일반 JSON 응답은 공통 봉투(success/code/message/data/page/timestamp/traceId)를 사용하며, SSE 스트리밍에는 봉투를 적용하지 않는다. 인증은 HttpOnly 쿠키 기반이다.",
    "version": "1.0.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "cookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "access_token"
      }
    },
    "schemas": {
      "PageMetaDto": {
        "type": "object",
        "properties": {
          "size": {
            "type": "number",
            "description": "이번 페이지 항목 수"
          },
          "hasNext": {
            "type": "boolean",
            "description": "다음 페이지 존재 여부"
          },
          "nextCursor": {
            "type": "string",
            "nullable": true,
            "description": "다음 페이지 커서(불투명 문자열)"
          }
        },
        "required": [
          "size",
          "hasNext",
          "nextCursor"
        ]
      },
      "ApiResponseDto": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "비즈니스 성공 여부"
          },
          "code": {
            "type": "string",
            "description": "코드 레지스트리 기반 식별자 (FE 분기용)"
          },
          "message": {
            "type": "string",
            "description": "사용자 표시용 메시지"
          },
          "page": {
            "nullable": true,
            "type": "object",
            "allOf": [
              {
                "$ref": "#/components/schemas/PageMetaDto"
              }
            ]
          },
          "timestamp": {
            "type": "string",
            "description": "응답 생성 시각 (ISO 8601)"
          },
          "traceId": {
            "type": "string",
            "description": "요청 추적 ID (로그·알림과 연결)"
          }
        },
        "required": [
          "success",
          "code",
          "message",
          "page",
          "timestamp",
          "traceId"
        ]
      },
      "HealthResponseDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "ok"
          }
        },
        "required": [
          "status"
        ]
      },
      "ClinicSummaryResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "name"
        ]
      },
      "ClinicianResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "displayName": {
            "type": "string"
          },
          "clinic": {
            "$ref": "#/components/schemas/ClinicSummaryResponseDto"
          },
          "verificationStatus": {
            "type": "string",
            "enum": [
              "PENDING",
              "VERIFIED",
              "REJECTED"
            ]
          }
        },
        "required": [
          "id",
          "email",
          "displayName",
          "clinic",
          "verificationStatus"
        ]
      },
      "AuthSessionResponseDto": {
        "type": "object",
        "properties": {
          "clinician": {
            "$ref": "#/components/schemas/ClinicianResponseDto"
          },
          "expiresAt": {
            "type": "string",
            "description": "access 토큰 만료 시각 (ISO 8601)"
          }
        },
        "required": [
          "clinician",
          "expiresAt"
        ]
      },
      "SignUpRequestDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "doctor@clinic.kr"
          },
          "password": {
            "type": "string",
            "minLength": 10
          },
          "displayName": {
            "type": "string",
            "example": "김의사"
          },
          "clinicName": {
            "type": "string",
            "example": "서울한의원"
          },
          "licenseNumber": {
            "type": "string",
            "description": "면허번호 — 저장 시 암호화된다"
          },
          "termsAccepted": {
            "type": "boolean",
            "description": "true 필수"
          }
        },
        "required": [
          "email",
          "password",
          "displayName",
          "clinicName",
          "licenseNumber",
          "termsAccepted"
        ]
      },
      "LoginRequestDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "doctor@clinic.kr"
          },
          "password": {
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "EmailAvailabilityResponseDto": {
        "type": "object",
        "properties": {
          "available": {
            "type": "boolean"
          }
        },
        "required": [
          "available"
        ]
      },
      "GuidelineSummaryResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string",
            "example": "요통 한의표준임상진료지침"
          },
          "publisher": {
            "type": "string",
            "example": "한국한의약진흥원"
          },
          "currentVersion": {
            "type": "string",
            "example": "1.0"
          },
          "publishedAt": {
            "type": "string",
            "description": "현재 버전 발행일 (ISO 8601)"
          },
          "status": {
            "type": "string",
            "enum": [
              "ACTIVE",
              "SUPERSEDED"
            ]
          }
        },
        "required": [
          "id",
          "title",
          "publisher",
          "currentVersion",
          "publishedAt",
          "status"
        ]
      },
      "GuidelineDetailResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string",
            "example": "요통 한의표준임상진료지침"
          },
          "publisher": {
            "type": "string",
            "example": "한국한의약진흥원"
          },
          "currentVersion": {
            "type": "string",
            "example": "1.0"
          },
          "publishedAt": {
            "type": "string",
            "description": "현재 버전 발행일 (ISO 8601)"
          },
          "status": {
            "type": "string",
            "enum": [
              "ACTIVE",
              "SUPERSEDED"
            ]
          },
          "sourceUrl": {
            "type": "string",
            "description": "NCKM 원문 링크 — PDF는 재배포하지 않는다 (§5.4)"
          }
        },
        "required": [
          "id",
          "title",
          "publisher",
          "currentVersion",
          "publishedAt",
          "status",
          "sourceUrl"
        ]
      },
      "RatingResponseDto": {
        "type": "object",
        "properties": {
          "system": {
            "type": "string",
            "example": "GRADE"
          },
          "code": {
            "type": "string",
            "example": "A"
          },
          "label": {
            "type": "string",
            "example": "강한 권고"
          }
        },
        "required": [
          "system",
          "code",
          "label"
        ]
      },
      "EvidenceSummaryResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "sectionPath": {
            "example": [
              "2",
              "치료",
              "침치료"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "recommendationNumber": {
            "type": "string",
            "example": "R1"
          },
          "excerpt": {
            "type": "string",
            "description": "본문 발췌 (200자 축약)"
          },
          "recommendationGrade": {
            "$ref": "#/components/schemas/RatingResponseDto"
          },
          "evidenceLevel": {
            "$ref": "#/components/schemas/RatingResponseDto"
          }
        },
        "required": [
          "id",
          "sectionPath",
          "excerpt"
        ]
      },
      "EvidenceDetailResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "guidelineId": {
            "type": "string"
          },
          "guidelineVersionId": {
            "type": "string"
          },
          "guidelineTitle": {
            "type": "string"
          },
          "version": {
            "type": "string",
            "example": "1.0"
          },
          "sectionPath": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "recommendationNumber": {
            "type": "string"
          },
          "recommendationText": {
            "type": "string",
            "description": "권고문 원문 (권고 청크인 경우)"
          },
          "recommendationGrade": {
            "$ref": "#/components/schemas/RatingResponseDto"
          },
          "evidenceLevel": {
            "$ref": "#/components/schemas/RatingResponseDto"
          },
          "excerpt": {
            "type": "string",
            "description": "본문 발췌 전문"
          },
          "pageStart": {
            "type": "number"
          },
          "pageEnd": {
            "type": "number"
          },
          "sourceUrl": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "guidelineId",
          "guidelineVersionId",
          "guidelineTitle",
          "version",
          "sectionPath",
          "excerpt",
          "sourceUrl"
        ]
      }
    }
  }
}
